<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<GUIProfiles>
    <Presets>
        <Preset name="hpColorWhite" value="1 1 1 1"/>
        <Preset name="hpColorListHeaderBackground" value="0 0 0 0.35" />
    </Presets>

    <Profile name="hpHeaderLeft" extends="baseReference" with="anchorTopLeft pivotTopLeft">
        <imageColor value="0 0 0 0" />
        <textFocusedColor value="$preset_fs25_colorMainHighlight" />
        <textHighlightedColor value="$preset_fs25_colorMainHighlight" />
        <textSize value="16px" />
        <textBold value="true" />
        <textUpperCase value="true" />
        <textColor value="$preset_colorWhite_50" />
        <textAlignment value="left" />
        <textDisabledColor value="$preset_colorDisabled" />
    </Profile>

    <Profile name="hpHeaderRight" extends="hpHeaderLeft">
        <textAlignment value="right" />
    </Profile>

    <Profile name="hpList" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft" />

    <Profile name="hpHeaderBox" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft">
        <imageColor value="$preset_hpColorListHeaderBackground"/>
    </Profile>

    <Profile name="hpDetailBox" extends="emptyPanel" with="anchorStretchingYLeft pivotTopLeft">
        <imageColor value="0 0 0 0.45"/>
    </Profile>

    <Profile name="hpListItem" extends="baseReference" with="anchorTopStretchingX alternating">
        <height value="40px"/>
        <imageColor value="$preset_fs25_colorGrey" />
        <imageSelectedColor value="$preset_fs25_colorMainHighlight" />
        <alternateBackgroundColor value="$preset_fs25_colorGreyDark_50" />
    </Profile>

    <Profile name="hpRowCellLeft" extends="baseReference" with="anchorStretchingYLeft">
        <textBold value="false" />
        <textSize value="15px" />
        <textAlignment value="left" />
        <textColor value="$preset_fs25_colorMainLight" />
        <textSelectedColor value="$preset_fs25_colorMainDark" />
        <textDisabledColor value="$preset_colorDisabled" />
    </Profile>

    <Profile name="hpRowCellRight" extends="hpRowCellLeft">
        <textAlignment value="right" />
    </Profile>

    <Profile name="hpMetaText" extends="baseReference" with="anchorTopLeft pivotTopLeft">
        <imageColor value="0 0 0 0" />
        <textSize value="15px" />
        <textColor value="$preset_fs25_colorMainLight" />
        <textDisabledColor value="$preset_colorDisabled" />
        <textAlignment value="left" />
    </Profile>

    <Profile name="hpButtonClear" extends="buttonExtra1">
        <inputAction value="" />
    </Profile>

    <Profile name="hpButtonSave" extends="buttonExtra1">
        <inputAction value="MENU_ACCEPT" />
    </Profile>
</GUIProfiles>
